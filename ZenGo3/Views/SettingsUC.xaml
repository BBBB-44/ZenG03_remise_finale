<UserControl
    x:Class="ZenGo3.SettingsUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ZenGo3"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid
        x:Name="settingsUC"
        Margin="10"
        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

        <Grid.RowDefinitions>

            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!--  Top Section: Input Panels  -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left Panel - Dark Theme  -->
            <Border
                Grid.Column="0"
                Padding="30"
                Background="#000000"
                CornerRadius="15,0,0,0">
                <StackPanel>
                    <!--  Nom Field  -->
                    <Label Content="Nom" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="NomDarkTextBox" Style="{StaticResource InputStyle}" />

                    <!--  Surnom Field  -->
                    <Label Content="Surnom" Style="{StaticResource LabelStyle}" />
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding GameStats.BlackSurnom, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!--  Right Panel  -->
            <Border
                Grid.Column="1"
                Padding="30"
                Background="White"
                BorderBrush="Black"
                BorderThickness="2"
                CornerRadius="0,15,0,0">
                <StackPanel>
                    <!--  Nom Field  -->
                    <Label Content="Nom" Style="{StaticResource LabelStyle}" />
                    <TextBox Style="{StaticResource InputStyle}" />

                    <!--  Surnom Field  -->
                    <Label Content="Surnom" Style="{StaticResource LabelStyle}" />
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding GameStats.WhiteSurnom, Mode=TwoWay}" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Bottom Section: Game Settings  -->
        <Border
            Grid.Row="21"
            BorderBrush="Black"
            BorderThickness="2"
            CornerRadius="0,0,15,15">
            <Grid Margin="10" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Settings on the Left  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

                    <!--  Taille du jeu  -->
                    <StackPanel Margin="8" Orientation="Vertical">
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="Black"
                            Text="Taille du jeu" />
                        <ComboBox
                            x:Name="TailleComboBox"
                            SelectedIndex="0"
                            SelectedValue="{Binding GridText, Mode=TwoWay}"
                            SelectedValuePath="Content"
                            Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem Selector.IsSelected="True">9x9</ComboBoxItem>
                            <ComboBoxItem IsEnabled="False">13x13</ComboBoxItem>
                            <ComboBoxItem IsEnabled="False">19x19</ComboBoxItem>
                        </ComboBox>

                    </StackPanel>

                    <!--  Handicap  -->
                    <StackPanel Margin="8" Orientation="Vertical">
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="Black"
                            Text="Handicap" />
                        <ComboBox
                            x:Name="HandicapComboBox"
                            IsEnabled="True"
                            SelectedValue="{Binding GameStats.Handicap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValuePath="Content"
                            Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem>None</ComboBoxItem>
                            <ComboBoxItem>1</ComboBoxItem>
                            <ComboBoxItem>2</ComboBoxItem>
                            <ComboBoxItem>3</ComboBoxItem>
                            <ComboBoxItem>4</ComboBoxItem>
                            <ComboBoxItem>5</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <!--  Komi  -->
                    <StackPanel
                        MinWidth="160"
                        Margin="8"
                        Orientation="Vertical">
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="Black"
                            Text="{Binding GameStats.Komi, StringFormat='Komi {0}'}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>



                            <Slider
                                x:Name="KomiSlider"
                                IsSnapToTickEnabled="True"
                                Maximum="8.5"
                                Minimum="0.5"
                                Style="{StaticResource SliderStyle}"
                                TickFrequency="1"
                                Value="{Binding GameStats.Komi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />


                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!--  Play Button on the Right  -->
                <Button
                    x:Name="PlayButton"
                    Grid.Column="1"
                    Command="{Binding PlayCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Jouer &gt;"
                    Cursor="Hand"
                    Style="{StaticResource PrimaryButton}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
