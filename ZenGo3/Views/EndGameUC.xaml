<UserControl
    x:Class="ZenGo3.EndGameUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ZenGo3"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ZenGo3.ViewModels"
    mc:Ignorable="d">

    <d:Window.DataContext>
        <vm:Window1VM />
    </d:Window.DataContext>
    <Grid x:Name="endGameUC" Grid.Row="1">
        <Border CornerRadius="15">
            <Border
                Margin="20"
                Background="#D4A373"
                CornerRadius="15">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="32"
                        FontWeight="Bold"
                        Text="Partie terminée !" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="22"
                        Text="{Binding GameStats.TotalTime, StringFormat='Durée : {0:mm\\:ss}'}" />


                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="22"
                        Text="{Binding GameStats.Handicap, StringFormat='Handicap : {0}'}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="22"
                        Text="{Binding GameStats.Komi, StringFormat='Komi : {0}'}" />
                    <TextBlock
                        Margin="0,15"
                        HorizontalAlignment="Center"
                        FontSize="26"
                        Text="{Binding WinnerMessage}" />
                    <StackPanel Margin="0,25" Orientation="Horizontal">
                        <StackPanel Margin="30,0">
                            <TextBlock FontSize="22" Text="⚫ Noir" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="22"
                                Foreground="Black"
                                Text="{Binding GameStats.BlackSurnom, StringFormat='Surnom : {0}'}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="22"
                                Foreground="Black"
                                Text="{Binding GameStats.BlackScore, StringFormat='Score : {0}'}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="22"
                                Foreground="Black"
                                Text="{Binding GameStats.BlackCaptures, StringFormat='Captures : {0}'}" />

                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="22"
                                Foreground="Black"
                                Text="{Binding GameStats.BlackPlayTimeSeconds, StringFormat={}{0:mm\\:ss}}" />

                        </StackPanel>
                        <StackPanel Margin="30,0">
                            <TextBlock
                                FontSize="22"
                                Foreground="White"
                                Text="⚪ Blanc" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="22"
                                Foreground="Black"
                                Text="{Binding GameStats.WhiteSurnom, StringFormat='Surnom : {0}'}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="22"
                                Foreground="Black"
                                Text="{Binding GameStats.WhiteScore, StringFormat='Score : {0}'}" />

                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="22"
                                Foreground="Black"
                                Text="{Binding GameStats.WhiteCaptures, StringFormat='Captures : {0}'}" />

                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="22"
                                Foreground="Black"
                                Text="{Binding GameStats.WhitePlayTimeSeconds, StringFormat={}{0:mm\\:ss}}" />

                        </StackPanel>
                    </StackPanel>
                    <Button
                        Command="{Binding NewGameCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="Rejouer"
                        FontSize="20"
                        Style="{StaticResource PrimaryButton}" />
                    <Button
                        Command="{Binding MenuCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="Menu"
                        FontSize="20"
                        Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
