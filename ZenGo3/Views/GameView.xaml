<UserControl
    x:Class="ZenGo3.GameView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ZenGo3"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid HorizontalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="160" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="1"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Command="{Binding PasserTourCommand}"
                CommandParameter="{Binding ElementName=BoardCanvas}"
                Content="Passer son tour"
                IsEnabled="True"
                Style="{StaticResource PrimaryButton}" />
            <TextBlock
                Height="38"
                Margin="10"
                Padding="10"
                FontSize="13"
                Text="{Binding GameStats.Komi, StringFormat='Komi : {0}'}" />
            <Button
                Command="{Binding AbandonCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                Content="Abandonner"
                Style="{StaticResource PrimaryButton}" />

            <!--<Button
    Command="{Binding SuicideTestCommand}"
    CommandParameter="{Binding ElementName=BoardCanvas}"
    Content="Suicide test"
    IsEnabled="True"
    Style="{StaticResource PrimaryButton}" />-->
        </StackPanel>

        <!--  Black (left)  -->
        <Border
            Grid.Row="1"
            Grid.Column="0"
            Margin="12,8,8,8"
            Padding="12"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel>
                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                    <Border
                        Width="28"
                        Height="28"
                        Margin="0,0,8,0"
                        Background="Black"
                        CornerRadius="14" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="13"
                        Foreground="#444444"
                        Text="{Binding GameStats.BlackSurnom}" />
                </StackPanel>
                <TextBlock
                    Margin="0,12,0,0"
                    FontWeight="SemiBold"
                    Text="Temps de jeu" />
                <TextBlock FontSize="18" Text="{Binding GameStats.BlackPlayTimeSeconds, StringFormat={}{0:mm\\:ss}}" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontWeight="SemiBold"
                    Text="Prisonniers capturés" />
                <TextBlock FontSize="18" Text="{Binding GameStats.BlackCaptures}" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontWeight="SemiBold"
                    Text="Territoires" />
                <TextBlock FontSize="18" Text="{Binding GameStats.BlackTerritories}" />
            </StackPanel>
        </Border>

        <local:GridCanvas
            x:Name="BoardCanvas"
            Grid.Row="1"
            Grid.Column="1"
            Margin="14" />





        <!--  White (right)  -->
        <Border
            Grid.Row="1"
            Grid.Column="2"
            Margin="8,8,12,8"
            Padding="12"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel>

                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                    <Border
                        Width="28"
                        Height="28"
                        Margin="0,0,8,0"
                        Background="White"
                        BorderBrush="Black"
                        BorderThickness="1"
                        CornerRadius="14" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="13"
                        Foreground="#444444"
                        Text="{Binding GameStats.WhiteSurnom}" />
                </StackPanel>
                <TextBlock
                    Margin="0,12,0,0"
                    FontWeight="SemiBold"
                    Text="Temps de jeu" />
                <TextBlock FontSize="18" Text="{Binding GameStats.WhitePlayTimeSeconds, StringFormat={}{0:mm\\:ss}}" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontWeight="SemiBold"
                    Text="Prisonniers capturés" />
                <TextBlock FontSize="18" Text="{Binding GameStats.WhiteCaptures}" />
                <TextBlock
                    Margin="0,12,0,0"
                    FontWeight="SemiBold"
                    Text="Territoires" />
                <TextBlock FontSize="18" Text="{Binding GameStats.WhiteTerritories}" />
            </StackPanel>
        </Border>



    </Grid>

</UserControl>
